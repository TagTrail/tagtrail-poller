# TagTrail poller environment variables.
# Copy this file to `.env` for local runs, or import these into your
# deployment's secrets manager (Fly.io, GitHub Actions Secrets, etc).

# NOTE: There is no OAuth client id/secret here. TagTrail embeds a
# non-confidential Desktop-app OAuth credential in the poller source
# (poller/oauth_client.py), so every user shares it and nobody pastes a secret.
# (Forks running their own Google Cloud project may override via
#  GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET, but that's optional.)

# === Required: per-account Drive token ===
# Long-lived refresh token for the drive.file scope, printed by `tagtrail-gfmt-auth`.
GOOGLE_DRIVE_REFRESH_TOKEN=

# === Required: GoogleFindMyTools credentials bundle ===
# Base64-encoded copy of <gfmt_dir>/Auth/secrets.json, produced by
# `tagtrail-bootstrap`. The poller materializes it to disk on first start if
# Auth/secrets.json is missing, so cloud deploys do not need a mounted volume.
# Treat this like a password.
GFMT_SECRETS_JSON_B64=

# === Required: which trackers to poll ===
# Comma-separated canonical IDs (from `tagtrail-bootstrap` output).
TAGTRAIL_TRACKER_IDS=

# === Optional: friendly names & colours ===
# JSON objects keyed by canonical id.
# TAGTRAIL_TRACKER_NAMES={"abc123":"Keys","def456":"Backpack"}
# TAGTRAIL_TRACKER_COLORS={"abc123":"#2b6cb0","def456":"#dd6b20"}

# === Optional: tuning ===
# Default 900s (15 min). Be polite: avoid <600.
TAGTRAIL_POLL_INTERVAL_SECONDS=900
# Per-cycle wait for async FCM replies (s).
TAGTRAIL_REQUEST_TIMEOUT_SECONDS=90
# Drive folder name.
TAGTRAIL_FOLDER=TagTrail
